 gze=()=>{const[e,t]=m.useState({x:0,y:0});m.useEffect(()=>{const r=i=>{const a=window.innerWidth,s=window.innerHeight,o=i.clientX,l=i.clientY,u=a/2,c=s/2,f=(o-u)/u*40,h=(l-c)/c*100;t({x:f,y:h})};return document.addEventListener("mousemove",r),()=>document.removeEventListener("mousemove",r)},[]);const n=()=>{window.history.back()};return d.jsxs("div",{className:"min-h-screen flex items-center justify-center",style:{background:"#28254C",fontFamily:"Ubuntu, sans-serif"},children:[d.jsx("style",{children:`
        * {
          box-sizing: border-box;
        }

        .ghost-box {
          width: 350px;
          height: 100%;
          max-height: 600px;
          min-height: 450px;
          background: #332f63;
          border-radius: 20px;
          padding: 30px 50px;
          position: relative;
        }

        .ghost-container {
          padding: 15px 25px 25px;
          position: absolute;
          left: 50%;
          top: 30%;
          transform: translate(-50%, -30%);
        }

        .symbol:nth-child(1) {
          opacity: 0.2;
          animation: shine 4s ease-in-out 3s infinite;
        }

        .symbol:nth-child(1)::before,
        .symbol:nth-child(1)::after {
          content: "";
          width: 12px;
          height: 4px;
          background: #fff;
          position: absolute;
          border-radius: 5px;
          bottom: 65px;
          left: 0;
        }

        .symbol:nth-child(1)::before {
          transform: rotate(45deg);
        }

        .symbol:nth-child(1)::after {
          transform: rotate(-45deg);
        }

        .symbol:nth-child(2) {
          position: absolute;
          left: -5px;
          top: 30px;
          height: 18px;
          width: 18px;
          border: 4px solid #fff;
          border-radius: 50%;
          opacity: 0.2;
          animation: shine 4s ease-in-out 1.3s infinite;
        }

        .symbol:nth-child(3) {
          opacity: 0.2;
          animation: shine 3s ease-in-out 0.5s infinite;
        }

        .symbol:nth-child(3)::before,
        .symbol:nth-child(3)::after {
          content: "";
          width: 12px;
          height: 4px;
          background: #fff;
          position: absolute;
          border-radius: 5px;
          top: 5px;
          left: 40px;
        }

        .symbol:nth-child(3)::before {
          transform: rotate(90deg);
        }

        .symbol:nth-child(3)::after {
          transform: rotate(180deg);
        }

        .symbol:nth-child(4) {
          opacity: 0.2;
          animation: shine 6s ease-in-out 1.6s infinite;
        }

        .symbol:nth-child(4)::before,
        .symbol:nth-child(4)::after {
          content: "";
          width: 15px;
          height: 4px;
          background: #fff;
          position: absolute;
          border-radius: 5px;
          top: 10px;
          right: 30px;
        }

        .symbol:nth-child(4)::before {
          transform: rotate(45deg);
        }

        .symbol:nth-child(4)::after {
          transform: rotate(-45deg);
        }

        .symbol:nth-child(5) {
          position: absolute;
          right: 5px;
          top: 40px;
          height: 12px;
          width: 12px;
          border: 3px solid #fff;
          border-radius: 50%;
          opacity: 0.2;
          animation: shine 1.7s ease-in-out 7s infinite;
        }

        .symbol:nth-child(6) {
          opacity: 0.2;
          animation: shine 2s ease-in-out 6s infinite;
        }

        .symbol:nth-child(6)::before,
        .symbol:nth-child(6)::after {
          content: "";
          width: 15px;
          height: 4px;
          background: #fff;
          position: absolute;
          border-radius: 5px;
          bottom: 65px;
          right: -5px;
        }

        .symbol:nth-child(6)::before {
          transform: rotate(90deg);
        }

        .symbol:nth-child(6)::after {
          transform: rotate(180deg);
        }

        .ghost-body {
          background: #fff;
          width: 100px;
          height: 100px;
          border-radius: 100px 100px 0 0;
          position: relative;
          margin: 0 auto;
          animation: upndown 3s ease-in-out infinite;
        }

        .ghost-eyes {
          position: absolute;
          left: 50%;
          top: 45%;
          height: 12px;
          width: 70px;
          transform: translateX(-50%);
        }

        .eye-left {
          width: 12px;
          height: 12px;
          background: #332f63;
          border-radius: 50%;
          position: absolute;
          left: 10px;
        }

        .eye-right {
          width: 12px;
          height: 12px;
          background: #332f63;
          border-radius: 50%;
          position: absolute;
          right: 10px;
        }

        .ghost-bottom {
          display: flex;
          position: absolute;
          top: 100%;
          left: 0;
          right: 0;
        }

        .ghost-bottom div {
          flex-grow: 1;
          position: relative;
          top: -10px;
          height: 20px;
          border-radius: 100%;
          background-color: #fff;
        }

        .ghost-bottom div:nth-child(2n) {
          top: -12px;
          margin: 0;
          border-top: 15px solid #332f63;
          background: transparent;
        }

        .ghost-shadow {
          height: 20px;
          box-shadow: 0 50px 15px 5px #3b3769;
          border-radius: 50%;
          margin: 0 auto;
          animation: smallnbig 3s ease-in-out infinite;
        }

        .description {
          position: absolute;
          bottom: 30px;
          left: 50%;
          transform: translateX(-50%);
        }

        .description-container {
          color: #fff;
          text-align: center;
          width: 200px;
          font-size: 16px;
          margin: 0 auto;
        }

        .description-title {
          font-size: 24px;
          letter-spacing: 0.5px;
        }

        .description-text {
          color: #8c8aa7;
          line-height: 20px;
          margin-top: 20px;
        }

        .return-button {
          display: block;
          position: relative;
          background: #ff5e65;
          border: 1px solid transparent;
          border-radius: 50px;
          height: 50px;
          text-align: center;
          text-decoration: none;
          color: #fff;
          line-height: 50px;
          font-size: 18px;
          padding: 0 70px;
          white-space: nowrap;
          margin-top: 25px;
          transition: background 0.5s ease;
          overflow: hidden;
          cursor: pointer;
        }

        .return-button::before {
          content: "";
          position: absolute;
          width: 20px;
          height: 100px;
          background: #fff;
          bottom: -25px;
          left: 0;
          border: 2px solid #fff;
          transform: translateX(-50px) rotate(45deg);
          transition: transform 0.5s ease;
        }

        .return-button:hover {
          background: transparent;
          border-color: #fff;
        }

        .return-button:hover::before {
          transform: translateX(250px) rotate(45deg);
        }

        @keyframes upndown {
          0% {
            transform: translateY(5px);
          }
          50% {
            transform: translateY(15px);
          }
          100% {
            transform: translateY(5px);
          }
        }

        @keyframes smallnbig {
          0% {
            width: 90px;
          }
          50% {
            width: 100px;
          }
          100% {
            width: 90px;
          }
        }

        @keyframes shine {
          0% {
            opacity: 0.2;
          }
          25% {
            opacity: 0.1;
          }
          50% {
            opacity: 0.2;
          }
          100% {
            opacity: 0.2;
